{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "outDir": "./out/renderer",
    "rootDir": ".",
    "composite": true,
    "paths": {
      "@shared/*": ["./shared/*"],
      "@codingcode/core/*": ["../codingcode/src/*"]
    }
  },
  "include": ["src/**/*", "shared/**/*"],
  "exclude": ["node_modules", "out", "electron"],
  "references": [{ "path": "../codingcode" }, { "path": "../infra" }]
}
