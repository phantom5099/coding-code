{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2022"],
    "jsx": "react-jsx",
    "outDir": "./out",
    "rootDir": ".",
    "composite": false,
    "declaration": false
  },
  "include": ["electron/**/*", "shared/**/*"],
  "exclude": ["node_modules", "out", "src"]
}
